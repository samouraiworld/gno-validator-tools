server {
    listen 80 default_server;
    server_name _;

    location /loki/ {
        # Allow only validator nodes (private VLAN IPs)
{% for ip in loki_validator_ips %}
        allow {{ ip }};
{% endfor %}
        deny all;

        # Forward to Loki on monitoring server, inject Bearer token
        proxy_pass {{ loki_scheme | default('https') }}://{{ loki_domain }};
        proxy_set_header Host {{ loki_domain }};
        proxy_set_header Authorization "Bearer {{ loki_bearer_token }}";

        proxy_http_version 1.1;
        proxy_read_timeout 300s;
    }
}
