# Promtail configuration — sentry relay mode
# Logs are pushed to the sentry's loki-proxy which forwards to Loki.
# The sentry injects the Bearer token; validators do not need it.

server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: /tmp/positions.yaml

clients:
  - url: http://{{ sentry_private_ip | default(hostvars['gno-sentry']['private_ip']) }}/loki/api/v1/push
    batchsize: 102400
    batchwait: 2s

scrape_configs:
  - job_name: gnoland
    static_configs:
      - targets:
          - localhost
        labels:
          job: {{ promtail_job_name | default(moniker_validator) }}
          host: {{ inventory_hostname }}
          __path__: /var/lib/docker/containers/*/*.log

      - targets:
          - localhost
        labels:
          job: syslog
          host: {{ inventory_hostname }}
          __path__: /var/log/syslog
