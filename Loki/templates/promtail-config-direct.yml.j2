# Promtail configuration — direct mode (no sentry)
# Logs are pushed directly to Loki on the monitoring server over HTTPS.
# The Bearer token is included in the client configuration.

server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: /tmp/positions.yaml

clients:
  - url: https://{{ loki_domain }}/loki/api/v1/push
    bearer_token: {{ loki_bearer_token }}
    batchsize: 102400
    batchwait: 2s

scrape_configs:
  - job_name: gnoland
    static_configs:
      - targets:
          - localhost
        labels:
          job: {{ promtail_job_name | default(moniker_validator) }}
          host: {{ inventory_hostname }}
          __path__: /var/lib/docker/containers/*/*.log

      - targets:
          - localhost
        labels:
          job: syslog
          host: {{ inventory_hostname }}
          __path__: /var/log/syslog
