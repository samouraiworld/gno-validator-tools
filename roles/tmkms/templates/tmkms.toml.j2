# {{ ansible_managed }}
# tmkms config for the validator signer — softsign, same-host Unix socket.
# chain_id MUST match the gnoland genesis / config.toml tmkms_listener.chain_id.
# Paths refer to the mounts in the validator compose:
#   ./tmkms/tmkms.toml -> /tmkms/tmkms.toml
#   ./tmkms/secrets    -> /tmkms/secrets
#   ./tmkms/run        -> /run/gnoland (shared privval socket dir)

[[chain]]
id = "{{ tmkms_chain_id }}"
key_format = { type = "hex" }
state_file = "/tmkms/secrets/consensus_state.json"

[[providers.softsign]]
chain_ids = ["{{ tmkms_chain_id }}"]
key_type = "consensus"
key_format = "base64"
path = "/tmkms/secrets/consensus.key"

[[validator]]
chain_id = "{{ tmkms_chain_id }}"
addr = "unix://{{ tmkms_socket_path }}"   # same-host UDS; socket perms = auth
secret_key = "/tmkms/secrets/kms-identity.key"
protocol_version = "v0.34"
reconnect = true
