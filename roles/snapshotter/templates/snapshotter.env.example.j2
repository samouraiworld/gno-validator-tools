# snapshotter environment — COPY THIS TO .env AND FILL IT IN, THEN chmod 600 .env
#
#   cp snapshotter.env.example .env && chmod 600 .env
#
# .env holds the ONLY secrets on this host (Scaleway keys). It is never
# committed and never pushed to Object Storage. Do NOT put secrets in this
# .example file.

# --- P2P peers of the real network (node_id@host:port) --------------------
# At minimum the local sentry. Get its node_id with:
#   docker run --rm -v {{ snapshotter_source_node_dir }}/gnoland-data:/gnoroot/gnoland-data \
#     --entrypoint /usr/bin/gnoland {{ snapshotter_image }} secrets get node_id.id -raw
SEEDS=__FILL_ME__node_id@sentry_host:26656
PERSISTENT_PEERS=__FILL_ME__node_id@sentry_host:26656

# --- Scaleway Object Storage (rclone) -------------------------------------
# Create the bucket + an API key (Access/Secret) in the Scaleway console/IAM.
SCW_ACCESS_KEY=__FILL_ME__
SCW_SECRET_KEY=__FILL_ME__
S3_BUCKET={{ snapshotter_s3_bucket or 'gno-snapshots-prod' }}
S3_ENDPOINT={{ snapshotter_s3_endpoint }}
S3_REGION={{ snapshotter_s3_region }}
S3_PREFIX={{ snapshotter_s3_prefix }}

# --- Local snapshot retention (archives kept on disk) ---------------------
RETENTION_LOCAL={{ snapshotter_retention_local }}
