[Unit]
Description=NodeExporter
Wants=network-online.target
After=network-online.target
[Service]
User=exporter
Group=exporter
Type=simple
ExecStart=/opt/node_exporter/node_exporter  \
--collector.cpu \
--collector.meminfo \
--collector.loadavg \
--collector.filesystem
[Install]
WantedBy=multi-user.target