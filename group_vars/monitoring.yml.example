---
# =============================================================================
# gno-validator-tools — monitoring group vars
# Copy to group_vars/monitoring.yml and fill in your values.
# Add group_vars/monitoring.yml to .gitignore — never commit real secrets.
# =============================================================================

# --- Loki version -------------------------------------------------------------
# Binary downloaded from GitHub releases.
# Check https://github.com/grafana/loki/releases for the latest stable version.
loki_version: "3.4.2"

# Promtail version must match Loki version.
promtail_version: "3.4.2"

# --- Loki networking ----------------------------------------------------------
# Port Loki listens on locally. Never exposed directly — NGINX proxies it.
loki_http_port: 3100

# --- Loki domain and TLS ------------------------------------------------------
# Fully qualified domain name pointing to this monitoring server.
# A Let's Encrypt certificate will be issued for this domain.
loki_domain: ""
# Example: loki_domain: "mirador.example.com"

# Email address for Let's Encrypt certificate registration and renewal notices.
letsencrypt_email: ""
# Example: letsencrypt_email: "ops@example.com"

# --- Authentication -----------------------------------------------------------
# Bearer token used to authenticate log push requests to Loki.
#
# WARNING: Never store this value in plaintext in a file committed to git.
# Generate a strong random token:
#   openssl rand -hex 32
#
# Then encrypt it with ansible-vault:
#   ansible-vault encrypt_string 'your-token-here' --name 'loki_bearer_token'
#
# Paste the encrypted block here:
loki_bearer_token: ""
# Example (vault-encrypted):
# loki_bearer_token: !vault |
#   $ANSIBLE_VAULT;1.1;AES256
#   ...

# --- IP whitelist for Loki endpoint -------------------------------------------
# Only these IPs are allowed to push logs to /loki/ on the monitoring server.
# Add the public IP of each sentry node.
loki_allowed_ips: []
# Example:
# loki_allowed_ips:
#   - "51.159.14.234"     # gno-sentry production
#   - "51.159.103.166"    # gno-sentry-test12

# --- IP whitelist for loki-proxy (sentry side) --------------------------------
# Only these IPs are allowed to push through the sentry's loki-proxy.
# Add the private VLAN IPs of all validator nodes.
loki_validator_ips: []
# Example:
# loki_validator_ips:
#   - "172.16.12.2"       # gno-validator-1
#   - "172.16.12.3"       # gno-validator-2

# --- Loki retention -----------------------------------------------------------
# How long to keep logs (in hours). Default: 1440h = 60 days.
loki_retention_hours: 1440
