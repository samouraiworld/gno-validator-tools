# Pré-seed optionnel pour bootstrap.sh : copie en .env et règle tes images
# locales AVANT de lancer ./bootstrap.sh. bootstrap régénère ensuite .env en
# préservant ces valeurs (+ TMKMS_ALLOW une fois rempli).
#
#   cp .env.example .env   # puis édite, puis: ./bootstrap.sh

# Image du nœud gnoland. Doit contenir le support tmkms (mergé dans master,
# PR #5718 / commit a870686e4). Le tag GHCR ':master' l'inclut ; ':latest' NON
# (build de release trop ancien). Attention au chemin : c'est bien
# ghcr.io/gnolang/gno/gnoland (avec /gnoland), pas ghcr.io/gnolang/gno.
GNO_IMAGE=ghcr.io/gnolang/gno/gnoland:master

# Image gnogenesis (pour générer le genesis). Tag ':master' (évite les tags
# 'sha256-...' qui sont des artefacts d'attestation, pas l'image).
GNO_CONTRIBS_IMAGE=ghcr.io/gnolang/gno/gnocontribs:master

# Chain id (doit être identique côté tmkms)
CHAIN_ID=dev

# Rempli APRÈS le setup VM2 avec la pubkey kms (ed25519:<hex>). Laisser vide ici.
TMKMS_ALLOW=
